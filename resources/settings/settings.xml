    </setting>
    <setting propertyKey="@Properties.hebrewDateY" title="@Strings.SettingHebrewDateYTitle">
        <settingConfig type="numeric" min="-120" max="120" />
    </setting>
    <setting propertyKey="@Properties.shabbatTimesX" title="@Strings.SettingShabbatTimesXTitle">
        <settingConfig type="numeric" min="-120" max="120" />
    </setting>
    <setting propertyKey="@Properties.shabbatTimesY" title="@Strings.SettingShabbatTimesYTitle">
        <settingConfig type="numeric" min="-120" max="120" />
    </setting>
    <setting propertyKey="@Properties.batteryX" title="@Strings.SettingBatteryXTitle">
        <settingConfig type="numeric" min="-120" max="120" />
    </setting>
    <setting propertyKey="@Properties.batteryY" title="@Strings.SettingBatteryYTitle">
