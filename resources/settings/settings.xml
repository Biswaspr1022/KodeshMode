    </setting>
    <setting propertyKey="@Properties.statusY" title="@Strings.SettingStatusYTitle">
        <settingConfig type="numeric" min="-120" max="120" />
    </setting>
    <setting propertyKey="@Properties.hebrewDateX" title="@Strings.SettingHebrewDateXTitle">
