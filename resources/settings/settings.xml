    </setting>
    <setting propertyKey="@Properties.omerY" title="@Strings.SettingOmerYTitle">
        <settingConfig type="numeric" min="-120" max="120" />
    </setting>
    <setting propertyKey="@Properties.parashaX" title="@Strings.SettingParashaXTitle">
        <settingConfig type="numeric" min="-120" max="120" />
    </setting>
    <setting propertyKey="@Properties.parashaY" title="@Strings.SettingParashaYTitle">
